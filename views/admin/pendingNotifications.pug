extends ../layout

block content
  .div
    p
    .card
      h4 Pending Notifications

      .card
        h4 Legacy Agenda jobs remaining
        if agendaTotal === 0
          p(style="color: green") No Agenda jobs remaining — migration complete.
        else
          p Total: #{agendaTotal}
          table.table
            thead
              td Job type
              td Count
            each count, name in agendaByType
              tr
                td= name
                td= count

      - const qs = (s, p) => '?' + (s ? 'status=' + s : '') + (s && p ? '&' : '') + (p ? 'projectId=' + p : '')

      .admin-filters
        strong Filter by status:&nbsp;
        a(href="/admin/notifications" + (projectId ? '?projectId=' + projectId : '')) All
        | &nbsp;|&nbsp;
        a(href="/admin/notifications" + qs('pending', projectId)) Pending
        | &nbsp;|&nbsp;
        a(href="/admin/notifications" + qs('processing', projectId)) Processing
        | &nbsp;|&nbsp;
        a(href="/admin/notifications" + qs('sent', projectId)) Sent
        | &nbsp;|&nbsp;
        a(href="/admin/notifications" + qs('failed', projectId)) Failed
        | &nbsp;|&nbsp;
        a(href="/admin/notifications" + qs('cancelled', projectId)) Cancelled

      form(method="get" action="/admin/notifications" style="margin-top: 12px;")
        if status
          input(type="hidden" name="status" value=status)
        label(style="font-weight: bold") Filter by project:&nbsp;
        select(name="projectId")
          if !projectId
            option(value="" selected) All projects
          else
            option(value="") All projects
          each project in projects
            if projectId === project._id.toString()
              option(value=project._id selected)= project.name
            else
              option(value=project._id)= project.name
        button(type="submit") Apply

      if status === 'cancelled' || status === 'sent'
        form(method="post" action="/admin/notifications/delete-by-status" style="margin: 16px 0;" onsubmit=`return confirm('Delete all ${status} notifications? This cannot be undone.')`)
          input(type="hidden" name="status" value=status)
          if projectId
            input(type="hidden" name="projectId" value=projectId)
          button(type="submit")= `Delete all ${status}`

      .pagination
        .pagination__prev
          if page > 1
            a(href=`/admin/notifications/page/${page - 1}` + qs(status, projectId)) #{layout.pagination_prev}
        .pagination__text
          p= `${layout.pagination_page_1} ${page} ${layout.pagination_page_2} ${pages} - ${count} ${layout.pagination_page_3}`
        .pagination__next
          if page < pages
            a(href=`/admin/notifications/page/${parseFloat(page) + 1}` + qs(status, projectId)) #{layout.pagination_next}

      table.table
        thead
          td N.
          td Status
          td Scheduled For
          td Project
          td Title
          td Message
          td Recipients (users)
          td Recipients (groups)
          td Reminder
          td Config ID

        each n, i in notifications
          tr
            td #{i + 1 + skip}
            td= n.status
            td= h.moment(n.scheduledFor).format("MMM Do YY HH:mm")
            td
              if n.projectId && n.projectId.name
                = n.projectId.name
              else
                = n.projectId
            td= n.title
            td= n.message.split(' ').slice(0, 8).join(' ')
            td= n.recipientUserIds.length ? n.recipientUserIds.join(', ') : 'all'
            td= n.recipientGroupIds.length ? n.recipientGroupIds.join(', ') : '—'
            td= n.isReminder ? 'yes' : ''
            td= n.notificationConfigId

      .pagination
        .pagination__prev
          if page > 1
            a(href=`/admin/notifications/page/${page - 1}` + qs(status, projectId)) #{layout.pagination_prev}
        .pagination__text
          p= `${layout.pagination_page_1} ${page} ${layout.pagination_page_2} ${pages} - ${count} ${layout.pagination_page_3}`
        .pagination__next
          if page < pages
            a(href=`/admin/notifications/page/${parseFloat(page) + 1}` + qs(status, projectId)) #{layout.pagination_next}
